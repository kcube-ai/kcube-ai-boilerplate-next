# Application
APP_VERSION=1.0.0
APP_NAME=Medial AI
APP_PUBLIC_URL=https://medial.au
ENABLE_USER_EMAILS=true

# API
API_PREFIX=/api/v1

# CORS
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://medial.au,https://*.medial.au

# JWT
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=change-this
JWT_EXPIRE_MINUTES_DELTA=30

# SendGrid
SENDGRID_VERIFY_SSL=true
SENDGRID_API_KEY=change-this
SENDGRID_FROM_EMAIL=justin@medial.au

# Tokens
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=1

# Postgres
POSTGRES_PORT=5432
POSTGRES_DB=medial_ai
POSTGRES_USER=postgres
POSTGRES_SERVER=localhost
POSTGRES_PASSWORD=change-this

# Redis
REDIS_URL=change-this

# Azure OpenAI
AZURE_OPENAI_CHAT_MODEL=gpt-4o
AZURE_OPENAI_API_KEY=change-this
AZURE_OPENAI_VERSION=change-this
AZURE_OPENAI_ENDPOINT=change-this

# Google
GOOGLE_CLIENT_ID=change-this
GOOGLE_CLIENT_SECRET=change-this
GOOGLE_LOGIN_REDIRECT_URI=<APP_PUBLIC_URL>/google-login-redirect

# Xero
XERO_CLIENT_ID=change-this
XERO_CLIENT_SECRET=change-this
XERO_LOGIN_REDIRECT_URI=<APP_PUBLIC_URL>/xero-login-redirect
XERO_ORGANIZATION_REDIRECT_URI=<APP_PUBLIC_URL>/xero-organization-redirect

# Azure Key Vault
AZURE_KEY_VAULT_URL=change-this
AZURE_KEY_VAULT_TENANT_ID=change-this
AZURE_KEY_VAULT_CLIENT_ID=change-this
AZURE_KEY_VAULT_CLIENT_SECRET=change-this
